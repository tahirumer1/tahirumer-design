# ── Headless WordPress (primary content source) ──
# Set this and the site reads Projects/Testimonials/FAQs from WordPress.
# Leave it UNSET to keep using Sanity instead.
NEXT_PUBLIC_WP_API=https://cms.tahirumer.site/wp-json

# Sanity CMS Configuration (legacy — used only if NEXT_PUBLIC_WP_API is unset)
# Get these from https://www.sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: API token for authenticated requests (for drafts/previews)
# Create at https://www.sanity.io/manage → API → Tokens (Viewer role)
SANITY_API_READ_TOKEN=your_read_token_here
